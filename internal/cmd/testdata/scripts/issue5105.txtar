# test that chezmoi managed lists all managed files
exec chezmoi managed
cmp stdout golden/managed

# test that chezmoi managed --include create only lists files with the create_ attribute
exec chezmoi managed --include create
cmp stdout golden/managed_include_create

# test that chezmoi managed --exclude modify only lists files without the modify_ attribute
exec chezmoi managed --exclude modify
cmp stdout golden/managed_exclude_modify

-- golden/managed --
.create
.file
.modify
-- golden/managed_exclude_modify --
.file
.modify
-- golden/managed_include_create --
.create
-- home/user/.local/share/chezmoi/create_dot_create --
# contents of .create
-- home/user/.local/share/chezmoi/dot_file --
# contents of .file
-- home/user/.local/share/chezmoi/modify_dot_modify --
#!/bin/sh

echo "# contents of .modify"
